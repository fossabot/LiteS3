# Database Configuration
# Leave empty to use SQLite (file:.data/local.db) by default
# SQLite:     DATABASE_URL=file:.data/local.db
# Turso:      DATABASE_URL=libsql://my-db-xxx.turso.io
#             DATABASE_AUTH_TOKEN=your_auth_token_here
# PostgreSQL: DATABASE_URL=postgres://user:password@host:5432/dbname
DATABASE_URL=
DATABASE_AUTH_TOKEN=

# Auth
NEXTAUTH_SECRET=your_nextauth_secret_here

# Encryption
ENCRYPTION_KEY=your_encryption_key_here
